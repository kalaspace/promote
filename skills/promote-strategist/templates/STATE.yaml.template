# STATE.yaml — runtime state for campaign {campaign_id} (v1.4.0)
campaign_id: "{campaign_id}"
url: "{url}"
runtime_root: "{absolute_path_resolved_in_P0_step_1}"  # $PROMOTE_HOME | <cwd>/campaigns | ${CLAUDE_PLUGIN_DATA}/campaigns
mode: "guided"  # guided | autopilot | resume
phase: "P0"     # P0 | P0.5 | P1 | P1.5 | P2 | P3.A | P3.B | P3.C | P3.D | P3.E | P3.F | P4 | P5 | ready-for-executor | manual_review_needed
created: "{ISO-date}"
last_updated: "{ISO-date}"

# Product type detection (NEW v1.4.0, set at P0)
product_type: ""  # book | saas | course | service | hybrid

# P0.5 Product Content Ingestion (NEW v1.4.0)
product_content_path: "intake/product-content.md"
product_content_completeness: ""  # COMPLETE | PARTIAL | MISSING
product_content_ingested_at: ""

# P1.5 Claims Ledger (v1.3.0 + v1.4.0 STRUCTURE/EXAMPLES)
claims_ledger_path: "intake/verified-claims.csv"
never_claims_path: "intake/never-claims.txt"
claims_ledger_validated_at: ""
ledger_total_claims: 0
ledger_structure_examples_count: 0  # NEW v1.4.0 — count of STRUCTURE+EXAMPLES claims (sourced from product-content.md)

known_facts:
  product_name: ""
  one_liner: ""
  pricing: ""
  pricing_variants: ""
  jtbd_user_words: ""
  hidden_critical_feature: ""
  technical_primitive: ""
  ttv: ""
  icp_real: ""
  icp_niche_specific: ""
  user_described_category: ""
  alternatives: []
  ltv: ""
  margin: ""
  cac_target: ""
  free_offering: ""
  testimonials_with_numbers: ""
  existing_press: ""
  existing_content_count: 0
  primary_goal: ""  # awareness | leads | sales | retention | expansion
  goal_target: ""
  forbidden_claims: ""
  brand_tone: ""
  existing_channels: []
  forbidden_channels: []
  current_bottleneck: ""
  budget_constraints: ""

unknowns: []          # list of fields user said "don't know"
hypotheses_to_validate: []  # surface in strategy-summary

batches_completed: []  # ["B1", "B2", ...]
delegations_completed: []  # ["P3.A.jtbd", "P3.B.channel-strategist", ...]
operator_consultations_completed: []  # ["welsh-linkedin", "mcgarry-newsletter", ...]
warnings: []           # ["product_content_missing", "no_clear_diagnosis_from_inputs", ...]

# P4 Content production tracking v1.4.0 (single-run, full window)
window_days: 90  # configurable via --days N flag
full_window_concrete_count: 0
manual_review_needed_count: 0
posts_directory: "content/posts/"
meta_directory: "content/posts/.meta/"

# Atomization rotation state (v1.4.0 single-run, mapping pillar_id → list of variants used)
